programa {
  funcao inicio() {
    cadeia nome
    real idade
    inteiro ano_nacimento
    escreva("Qual é seu nome: ")
    leia(nome)
    escreva("que ano vc naceu: ")
    leia(ano_nacimento)
    idade = 2026-ano_nacimento

    escreva("ola ", nome ," voce tem aproximadamente ", idade , " anos")
  }
}
