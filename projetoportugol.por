programa {
  funcao inicio() {
    inteiro menor, idade
    escreva("informe sua ideade: ")
    leia(idade)

    se(idade < 18) {
      escreva("Menor de idade é Prohibido")
    }senao{
      escreva("Voce é de marior, por favor entre")
    }

    escreva("\n") // comando para quebrar a linha
  }
}
